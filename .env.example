# ─────────────────────────────────────────────
# AI Music Factory — 환경 변수
# ─────────────────────────────────────────────
# 이 파일을 .env로 복사 후 값을 채워주세요:
#   cp .env.example .env

# Opus 4.6 오케스트레이터 (Anthropic)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Lyria 3 Pro 음악 생성 (Google Gemini)
GEMINI_API_KEY=your-gemini-key-here

# YouTube 업로드 공개 상태 (public / unlisted / private)
YT_PRIVACY=unlisted

# 플레이리스트 저장 경로 (기본: ~/music/AI_Playlist)
# PLAYLIST_OUTPUT_DIR=C:/Users/yourname/music/AI_Playlist
